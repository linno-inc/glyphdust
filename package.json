{
  "name": "glyphdust",
  "version": "0.9.3",
  "description": "Text → particles → glyph → real-text resolve. One React-three-fiber component, or one React-free call: glyphText(\"#hero\", \"LINNO\").",
  "type": "module",
  "license": "MIT",
  "author": "LINNO (NOGUCHILin)",
  "homepage": "https://github.com/linno-inc/glyphdust#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linno-inc/glyphdust.git"
  },
  "bugs": {
    "url": "https://github.com/linno-inc/glyphdust/issues"
  },
  "keywords": [
    "particles",
    "text-animation",
    "scroll",
    "three",
    "three.js",
    "react-three-fiber",
    "r3f",
    "webgl",
    "glyph",
    "morph",
    "hero",
    "shader"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/glyphdust.min.js",
  "jsdelivr": "./dist/glyphdust.min.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cdn": "./dist/glyphdust.min.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.6.1",
    "@types/react": "^19.0.0",
    "@types/three": "^0.184.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
